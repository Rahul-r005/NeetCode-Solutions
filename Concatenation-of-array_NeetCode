class Solution {
    public int[] getConcatenation(int[] nums) {
        int [] nums1=new int [nums.length*2];
        int k=0;
        for(int i=0;i<nums1.length;i++,k++){
            if(i==nums.length){
                k=0;
            }
            nums1[i]=nums[k];
        }
        return nums1;
    }
}
