class Solution {
    public int[] replaceElements(int[] arr) { 
        for(int i=0;i<arr.length;i++){
            arr[i]=max(arr,i+1);
        }arr[arr.length-1]=-1;
        return arr;
    }
    public static int max(int[]nums,int start){ 
        int max=0;
        for(int i=start;i<nums.length;i++){
            if(max<nums[i]){
                max=nums[i];
            }
        }return max;
    }
}
