class Solution {
    public int findMaxConsecutiveOnes(int[] nums) {
        int c=0;
        int maxc=0;
        for(int i=0;i<nums.length;i++){
            if(nums[i]==1){
                c+=1;
            }else{
                maxc=Math.max(c,maxc);
                c=0;
            } maxc=Math.max(c,maxc);
        }return maxc;
    }
}
